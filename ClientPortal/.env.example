# Copie ce fichier en .env et remplis les valeurs réelles.
# Ne committe JAMAIS le .env — seulement ce .env.example.

# Clé secrète Flask (signe les cookies de session — génère avec: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-moi-une-longue-chaine-aleatoire

# Mot de passe admin initial (lu au démarrage pour créer le compte admin si inexistant)
ADMIN_PASSWORD=ton-mot-de-passe-admin

# Gmail (App Password — pas le vrai mot de passe — créé dans Compte Google > Sécurité > Mots de passe d'application)
GMAIL_USER=ton-adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mode maintenance (0 = normal, 1 = portail client bloqué)
MAINTENANCE_MODE=0

# Optionnel — chemin volume Railway en prod (laisser vide en local)
# RAILWAY_VOLUME_MOUNT_PATH=/data

# Token API Cloudflare (Mon Profil > API Tokens > permission "Account Analytics: Read")
# Utilisé par le dashboard Analytics pour lire les stats Web Analytics via l'API GraphQL
CLOUDFLARE_API_TOKEN=ton-token-cloudflare
# Account ID Cloudflare — visible dans l'URL du dashboard (dash.cloudflare.com/<account-id>/...)
CLOUDFLARE_ACCOUNT_ID=ton-account-id-cloudflare
